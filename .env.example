# smart_stage_brain.py loads this file from /etc/smart-stage.env (preferred)
# or from ./.env in the repo directory. Copy this file and fill in real values.
# .env is gitignored — do not commit real keys.

# Lecture summarization on graceful shutdown (DeepSeek chat API, OpenAI SDK)
DEEPSEEK_API_KEY=

# Discord webhook receiving the session summary when the brain shuts down
DISCORD_WEBHOOK_URL=

# Voice-assistant LLM (Google Gemini 2.5 Flash)
GEMINI_API_KEY=

# Voice-assistant TTS (Figurate character voice)
FIGURATE_API_KEY=
FIGURATE_CHAR_ID=
# FIGURATE_TTS_URL=https://disciplined-amazement-production.up.railway.app/api/voice/tts
